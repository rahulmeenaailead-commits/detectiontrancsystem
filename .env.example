# LLM provider — DeepSeek is the default (used for fraud reasoning)
DEEPSEEK_API_KEY=your_key_here

# Bright Data (SERP API — live merchant reputation lookups)
BRIGHTDATA_API_KEY=
# Must match an ACTIVE SERP zone in your account
# (check via GET https://api.brightdata.com/zone/get_active_zones).
BRIGHTDATA_SERP_ZONE=serp_api1
# Live SERP scrapes routinely take 10-25s; keep this generous.
BRIGHTDATA_TIMEOUT_SECONDS=30
MERCHANT_REPUTATION_TTL_HOURS=24

# Backend
SENTINEL_API_KEY=sentinel-dev-key
CORS_ORIGINS=http://localhost:3000
SENTINEL_ANALYZE_RATE=60/minute
SENTINEL_DB_PATH=sentinel.db

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTINEL_API_KEY=sentinel-dev-key
